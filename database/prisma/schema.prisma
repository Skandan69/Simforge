generator client {
  provider = "prisma-client"
  output   = "../../apps/api/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  Owner
  Admin
  Trainer
  Manager
  Learner
}

enum KnowledgeBaseStatus {
  Active
  Archived
}

enum DocumentFileType {
  PDF
  DOCX
  PPTX
  XLSX
}

enum DocumentStatus {
  Ready
  Archived
  Failed
}

enum ProcessingStatus {
  Uploaded
  Queued
  Processing
  Completed
  Failed
  Cancelled
}

enum KnowledgeSourceType {
  PDF
  DOCX
  PPTX
  XLSX
  Website
  Video
  Audio
  Image
  SharePoint
  Confluence
  API
}

enum ProcessingLogLevel {
  Info
  Warning
  Error
}

enum KnowledgeSectionType {
  Policy
  Procedure
  ProductInformation
  FAQ
  BestPractice
  Compliance
  GeneralReference
  Unknown
}

enum KnowledgeImportance {
  Critical
  Important
  Reference
  Optional
}

enum SimulationDifficulty {
  Beginner
  Intermediate
  Advanced
  Expert
}

enum SimulationStatus {
  Draft
  Active
  Archived
}

enum SimulationSessionStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum SimulationMessageRole {
  learner
  ai
  system
}

model Profile {
  id                    String            @id @db.Uuid
  email                 String            @unique
  fullName              String?
  avatarUrl             String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  memberships           Membership[]
  createdOrganizations  Organization[]    @relation("OrganizationCreator")
  activities            Activity[]
  knowledgeBasesCreated KnowledgeBase[]   @relation("KnowledgeBaseCreator")
  documentsUploaded     Document[]        @relation("DocumentUploader")
  versionsUploaded      DocumentVersion[] @relation("DocumentVersionUploader")
  simulationsCreated    Simulation[]       @relation("SimulationCreator")
  personasCreated       SimulationPersona[] @relation("PersonaCreator")
  criteriaCreated       SimulationEvaluationCriterion[] @relation("CriterionCreator")
  simulationSessions    SimulationSession[] @relation("SessionLearner")
}

model Organization {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  slug           String          @unique
  industry       String
  companySize    String
  country        String
  timezone       String
  logoUrl        String?
  createdBy      String          @db.Uuid
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  creator        Profile         @relation("OrganizationCreator", fields: [createdBy], references: [id])
  memberships    Membership[]
  activities     Activity[]
  knowledgeBases KnowledgeBase[]
  knowledgeSources KnowledgeSource[]
  simulations     Simulation[]
  simulationPersonas SimulationPersona[]
  evaluationCriteria SimulationEvaluationCriterion[]
  simulationSessions SimulationSession[]

  @@index([createdBy])
}

model KnowledgeBase {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @db.Uuid
  name           String
  description    String
  department     String
  status         KnowledgeBaseStatus @default(Active)
  createdBy      String              @db.Uuid
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator        Profile             @relation("KnowledgeBaseCreator", fields: [createdBy], references: [id])
  documents      Document[]
  simulationLinks SimulationKnowledgeBase[]

  @@unique([organizationId, name])
  @@index([organizationId, status])
  @@index([organizationId, department])
}

model Simulation {
  id                String               @id @default(uuid()) @db.Uuid
  organizationId    String               @db.Uuid
  title             String
  description       String
  industry          String
  department        String
  jobRole           String
  category          String
  difficulty        SimulationDifficulty
  status            SimulationStatus     @default(Draft)
  estimatedMinutes  Int
  personaId         String?              @db.Uuid
  scenarioSetup     String               @db.Text
  successCriteria   String               @db.Text
  createdBy         String               @db.Uuid
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator           Profile              @relation("SimulationCreator", fields: [createdBy], references: [id])
  persona           SimulationPersona?   @relation(fields: [personaId], references: [id], onDelete: SetNull)
  objectives        SimulationObjective[]
  evaluationCriteria SimulationCriterionLink[]
  knowledgeBases    SimulationKnowledgeBase[]
  versions          SimulationVersion[]
  sessions          SimulationSession[]

  @@index([organizationId, status])
  @@index([organizationId, department])
  @@index([organizationId, difficulty])
  @@index([personaId])
}

model SimulationPersona {
  id                 String       @id @default(uuid()) @db.Uuid
  organizationId     String       @db.Uuid
  name               String
  role               String
  personality        String
  tone               String
  difficultyBehavior String       @db.Text
  backgroundContext  String       @db.Text
  createdBy          String       @db.Uuid
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator            Profile      @relation("PersonaCreator", fields: [createdBy], references: [id])
  simulations        Simulation[]

  @@unique([organizationId, name])
  @@index([organizationId, updatedAt])
}

model SimulationObjective {
  id           String     @id @default(uuid()) @db.Uuid
  simulationId String     @db.Uuid
  title        String
  sortOrder    Int
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@unique([simulationId, sortOrder])
}

model SimulationEvaluationCriterion {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  name           String
  description    String
  isDefault      Boolean      @default(false)
  createdBy      String       @db.Uuid
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator        Profile      @relation("CriterionCreator", fields: [createdBy], references: [id])
  simulations    SimulationCriterionLink[]

  @@unique([organizationId, name])
  @@index([organizationId, updatedAt])
}

model SimulationCriterionLink {
  simulationId String                        @db.Uuid
  criterionId  String                        @db.Uuid
  simulation   Simulation                    @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  criterion    SimulationEvaluationCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)

  @@id([simulationId, criterionId])
  @@index([criterionId])
}

model SimulationKnowledgeBase {
  simulationId  String        @db.Uuid
  knowledgeBaseId String      @db.Uuid
  simulation    Simulation    @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@id([simulationId, knowledgeBaseId])
  @@index([knowledgeBaseId])
}

model SimulationVersion {
  id           String     @id @default(uuid()) @db.Uuid
  simulationId String     @db.Uuid
  version      Int
  snapshot     Json
  createdAt    DateTime   @default(now())
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@unique([simulationId, version])
}

model SimulationSession {
  id             String                  @id @default(uuid()) @db.Uuid
  organizationId String                  @db.Uuid
  simulationId   String                  @db.Uuid
  learnerId      String                  @db.Uuid
  status         SimulationSessionStatus @default(IN_PROGRESS)
  startedAt      DateTime                @default(now())
  completedAt    DateTime?
  overallScore   Float?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  simulation     Simulation              @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  learner        Profile                 @relation("SessionLearner", fields: [learnerId], references: [id], onDelete: Cascade)
  messages       SimulationMessage[]
  evaluation     SimulationEvaluation?
  capabilityScores CapabilityScore[]

  @@index([organizationId, createdAt])
  @@index([simulationId, status])
  @@index([learnerId, createdAt])
}

model SimulationMessage {
  id        String                @id @default(uuid()) @db.Uuid
  sessionId String                @db.Uuid
  role      SimulationMessageRole
  content   String                @db.Text
  createdAt DateTime              @default(now())
  session   SimulationSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model SimulationEvaluation {
  id                      String            @id @default(uuid()) @db.Uuid
  sessionId               String            @unique @db.Uuid
  overallScore            Float
  strengths               Json
  improvementAreas        Json
  evidence                 Json
  recommendedNextPractice String            @db.Text
  createdAt               DateTime          @default(now())
  session                 SimulationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model CapabilityScore {
  id               String            @id @default(uuid()) @db.Uuid
  sessionId        String            @db.Uuid
  capabilityName   String
  score            Float
  evidence         String            @db.Text
  recommendation   String            @db.Text
  createdAt        DateTime          @default(now())
  session          SimulationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, capabilityName])
  @@index([sessionId])
}

model Document {
  id              String            @id @default(uuid()) @db.Uuid
  knowledgeBaseId String            @db.Uuid
  fileName        String
  fileType        DocumentFileType
  mimeType        String
  sizeBytes       BigInt
  storagePath     String            @unique
  uploadedBy      String            @db.Uuid
  uploadedAt      DateTime          @default(now())
  currentVersion  Int               @default(1)
  status          DocumentStatus    @default(Ready)
  notes           String            @default("")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  knowledgeBase   KnowledgeBase     @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  uploader        Profile           @relation("DocumentUploader", fields: [uploadedBy], references: [id])
  versions        DocumentVersion[]
  knowledgeSource KnowledgeSource?
  knowledgeChunks KnowledgeChunk[]

  @@index([knowledgeBaseId, status])
  @@index([uploadedBy])
  @@index([fileName])
}

model KnowledgeSource {
  id                   String              @id @default(uuid()) @db.Uuid
  organizationId       String              @db.Uuid
  documentId           String?             @unique @db.Uuid
  sourceType           KnowledgeSourceType
  title                String
  mimeType             String?
  sizeBytes            BigInt?
  status               ProcessingStatus    @default(Uploaded)
  progress             Int                 @default(0)
  extractedText        String?             @db.Text
  pageCount            Int?
  wordCount            Int?
  characterCount       Int?
  estimatedTokens      Int?
  language             String?
  processingDurationMs Int?
  processedAt          DateTime?
  failureReason        String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  organization         Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document             Document?           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  jobs                 ProcessingJob[]
  chunks               KnowledgeChunk[]
  logs                 ProcessingLog[]
  intelligenceSections KnowledgeIntelligenceSection[]

  @@index([organizationId, status])
  @@index([sourceType])
}

model KnowledgeIntelligenceSection {
  id             String              @id @default(uuid()) @db.Uuid
  sourceId       String              @db.Uuid
  sectionNumber  Int
  title          String
  summary        String              @db.Text
  sectionType    KnowledgeSectionType
  confidence     Float
  keywords       String[]
  importance     KnowledgeImportance
  capabilities   String[]
  isAiSuggestion Boolean             @default(true)
  analysisVersion String             @default("heuristic-v0.1")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  source         KnowledgeSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, sectionNumber])
  @@index([sourceId, sectionType])
}

model ProcessingJob {
  id                String           @id @default(uuid()) @db.Uuid
  sourceId          String           @db.Uuid
  status            ProcessingStatus @default(Queued)
  progress          Int              @default(0)
  attempt           Int              @default(0)
  retryCount        Int              @default(0)
  maxAttempts       Int              @default(3)
  queuedAt          DateTime         @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  cancelRequestedAt DateTime?
  lastAttemptAt     DateTime?
  durationMs        Int?
  failureReason     String?
  errorMessage      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  source            KnowledgeSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  logs              ProcessingLog[]

  @@index([status, queuedAt])
  @@index([sourceId, createdAt])
}

model KnowledgeChunk {
  id             String          @id @default(uuid()) @db.Uuid
  sourceId       String          @db.Uuid
  documentId     String?         @db.Uuid
  chunkNumber    Int
  text           String          @db.Text
  characterCount Int
  estimatedTokens Int
  metadata       Json
  createdAt      DateTime        @default(now())
  source         KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  document       Document?       @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([sourceId, chunkNumber])
  @@index([documentId])
}

model ProcessingLog {
  id        String             @id @default(uuid()) @db.Uuid
  sourceId  String             @db.Uuid
  jobId     String?            @db.Uuid
  level     ProcessingLogLevel @default(Info)
  event     String
  message   String
  details   Json?
  createdAt DateTime           @default(now())
  source    KnowledgeSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  job       ProcessingJob?     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([sourceId, createdAt])
  @@index([jobId, createdAt])
}

model DocumentVersion {
  id          String           @id @default(uuid()) @db.Uuid
  documentId  String           @db.Uuid
  version     Int
  fileName    String
  fileType    DocumentFileType
  mimeType    String
  sizeBytes   BigInt
  storagePath String           @unique
  uploadedBy  String           @db.Uuid
  uploadedAt  DateTime         @default(now())
  notes       String           @default("")
  document    Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploader    Profile          @relation("DocumentVersionUploader", fields: [uploadedBy], references: [id])

  @@unique([documentId, version])
  @@index([uploadedBy])
}

model Membership {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  userId         String       @db.Uuid
  role           UserRole     @default(Learner)
  joinedAt       DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Activity {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  actorId        String?      @db.Uuid
  action         String
  description    String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          Profile?     @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorId])
}
